<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="150" prefWidth="300" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fi.jyu.ohj2.aleksi.huoneisto.controller.AsukasController">
    <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" VBox.vgrow="ALWAYS">
        <VBox.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
        </VBox.margin>
        <VBox alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="100.0" spacing="2.0">
            <HBox prefHeight="100.0" prefWidth="200.0">
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Nimi"/>
            </HBox>
            <TextField fx:id="asukkaanNimi"/>
        </VBox>
        <VBox alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="100.0" spacing="2.0">
            <HBox prefHeight="100.0" prefWidth="200.0">
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Ika"/>
            </HBox>
            <TextField fx:id="asukkaanIka"/>
        </VBox>
        <VBox alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="100.0" spacing="2.0">
            <VBox.margin>
                <Insets/>
            </VBox.margin>
            <HBox prefHeight="100.0" prefWidth="200.0">
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Sahkoposti tai puhelinnumero"/>
            </HBox>
            <TextField fx:id="asukkaanYhteystiedot"/>
        </VBox>
    </VBox>
    <HBox alignment="CENTER" prefHeight="78.0" prefWidth="600.0" spacing="10.0">
        <VBox.margin>
            <Insets bottom="10.0" left="20.0" right="20.0"/>
        </VBox.margin>
        <Button fx:id="vahvistaAsukasPainike" mnemonicParsing="false" text="Vahvista"/>
        <Button fx:id="suljeAsukasPainike" mnemonicParsing="false" text="Sulje"/>
    </HBox>
</VBox>
