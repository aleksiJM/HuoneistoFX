<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="150.0" prefWidth="300.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.aleksi.huoneisto.controller.AsuntoController">
    <children>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Asunnon tunnus" />
                  <TextField fx:id="asunnonTunnus" />
               </children>
               <HBox.margin>
                  <Insets left="10.0" right="10.0" top="20.0" />
               </HBox.margin>
            </VBox>
         </children>
      </HBox>
        <HBox alignment="CENTER" prefHeight="78.0" prefWidth="600.0" spacing="10.0" VBox.vgrow="NEVER">
            <children>
                <Button fx:id="vahvistaAsuntoPainike" mnemonicParsing="false" text="Vahvista" />
                <Button fx:id="suljeAsuntoPainike" mnemonicParsing="false" text="Sulje" />
            </children>
            <VBox.margin>
                <Insets left="20.0" right="20.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
