<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="535.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.aleksi.huoneisto.controller.MainController">
   <children>
      <TableView fx:id="asuntoTaulukko" prefHeight="500.0" prefWidth="600.0" VBox.vgrow="ALWAYS">
         <VBox.margin>
            <Insets left="10.0" right="10.0" top="30.0" />
         </VBox.margin>
      </TableView>
      <HBox alignment="CENTER_LEFT" prefHeight="78.0" prefWidth="600.0" spacing="10.0" VBox.vgrow="NEVER">
         <children>
            <Button fx:id="lisaaAsuntoPainike" mnemonicParsing="false" text="Lisää asunto" />
            <Button fx:id="muokkaaAsuntoaPainike" mnemonicParsing="false" text="Muokkaa" />
            <Button fx:id="poistaAsuntoPainike" mnemonicParsing="false" text="Poista" />
         </children>
         <VBox.margin>
            <Insets />
         </VBox.margin>
         <padding>
            <Insets left="20.0" />
         </padding>
      </HBox>
   </children>
</VBox>
