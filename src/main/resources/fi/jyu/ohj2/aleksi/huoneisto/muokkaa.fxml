<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="535.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fi.jyu.ohj2.aleksi.huoneisto.controller.MuokkaaController">
    <children>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Asunto: " />
         </children>
         <VBox.margin>
            <Insets bottom="10.0" top="10.0" />
         </VBox.margin>
      </HBox>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Asukkaat" />
         </children>
         <VBox.margin>
            <Insets bottom="10.0" left="10.0" />
         </VBox.margin>
      </HBox>
        <TableView prefHeight="500.0" prefWidth="600.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn prefWidth="84.0" text="Nimi" />
                <TableColumn prefWidth="91.0" text="Ikä" />
            <TableColumn prefWidth="236.0" text="Sähköposti tai puhelinnumero" />
            </columns>
            <VBox.margin>
                <Insets left="10.0" right="10.0" />
            </VBox.margin>
        </TableView>
        <HBox alignment="CENTER" prefHeight="78.0" prefWidth="600.0" spacing="10.0" VBox.vgrow="NEVER">
            <children>
                <Button fx:id="lisaaAsukasPainike" mnemonicParsing="false" text="Lisää asukas" />
                <Button fx:id="poistaAsukasPainike" mnemonicParsing="false" text="Poista asukas" />
                <Button fx:id="suljeMuokkausPainike" mnemonicParsing="false" text="Sulje" />
            </children>
            <VBox.margin>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
