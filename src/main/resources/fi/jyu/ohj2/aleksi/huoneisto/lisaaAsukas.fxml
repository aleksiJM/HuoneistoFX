<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="535.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fi.jyu.ohj2.aleksi.huoneisto.MainController">
    <children>
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0">
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Nimi" />
                        <TextField fx:id="asukkaanNimi" />
                    </children>
                    <HBox.margin>
                        <Insets left="10.0" right="10.0" top="20.0" />
                    </HBox.margin>
                </VBox>
                <VBox alignment="CENTER" layoutX="409.0" layoutY="10.0" prefHeight="200.0" prefWidth="100.0">
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Ika" />
                        <TextField fx:id="asukkaanIka" />
                    </children>
                    <HBox.margin>
                        <Insets left="10.0" right="10.0" top="20.0" />
                    </HBox.margin>
                </VBox>
            <VBox alignment="CENTER" layoutX="320.0" layoutY="30.0" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Sahkoposti tai puhelinnumero" />
                  <TextField fx:id="asukkaanYhteystiedot" />
               </children>
               <HBox.margin>
                  <Insets left="10.0" right="10.0" top="20.0" />
               </HBox.margin>
            </VBox>
            </children>
        </HBox>
        <HBox alignment="CENTER" prefHeight="78.0" prefWidth="600.0" spacing="10.0" VBox.vgrow="NEVER">
            <children>
                <Button mnemonicParsing="false" onAction="#vahvistaAsukas" text="Vahvista" />
                <Button mnemonicParsing="false" onAction="#suljeAsukas" text="Sulje" />
            </children>
            <VBox.margin>
                <Insets left="20.0" right="20.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
